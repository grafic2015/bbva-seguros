# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno.
# Copiá este archivo como ".env" y completá con tus datos reales.
# El .env real NO se sube al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Instagram Monitor - para capturar leads de seguros
# IMPORTANTE: Las credenciales deben estar ENCRIPTADAS
# Ejecuta: python encrypt_credentials.py para generar los valores encriptados
INSTAGRAM_EMAIL=gAAAAABm...  # Valor encriptado (ejecuta encrypt_credentials.py)
INSTAGRAM_PASSWORD=gAAAAABm...  # Valor encriptado (ejecuta encrypt_credentials.py)
INSTAGRAM_ACCOUNTS=bbva,seguros_bbva
