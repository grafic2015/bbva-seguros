# ═════════════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO - BBVA Seguros
# Copia este archivo como ".env" en la raíz del proyecto
# El archivo .env real NO se sube al repositorio (está en .gitignore)
# ═════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────
# 📦 AMBIENTE
# ─────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────
# 🗄️  BASE DE DATOS - Supabase (PostgreSQL Managed)
# ─────────────────────────────────────────────────────────────────────────
# 📌 Obtén en: https://app.supabase.com
# 1. Crear proyecto
# 2. Settings > Database > Connection string
# 3. Copiar y pegar aquí

DATABASE_URL=postgresql://postgres.xxxxxxxx:YourPassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Alternativa: Usar el URL sin pooler (más lento pero funciona)
# DATABASE_URL=postgresql://postgres:YourPassword@db.xxxxxxxx.supabase.co:5432/postgres

# Supabase API (para features avanzadas)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────
# 🔑 OPENAI API (requerido)
# ─────────────────────────────────────────────────────────────────────────
# Obtén tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_key_here
OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────
# 📱 INSTAGRAM MONITOR (requerido)
# ─────────────────────────────────────────────────────────────────────────
# ⚠️  IMPORTANTE: Usa "contraseña de aplicación", NO tu contraseña real
# Cómo obtenerla: https://help.instagram.com/1075259541848590
INSTAGRAM_EMAIL=your_instagram_email@gmail.com
INSTAGRAM_PASSWORD=your_app_password_here
INSTAGRAM_ACCOUNTS=bbva,seguros_bbva

# ─────────────────────────────────────────────────────────────────────────
# 🌐 SERVIDOR
# ─────────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
UVICORN_WORKERS=4

# ─────────────────────────────────────────────────────────────────────────
# ☁️  ORACLE CLOUD - Configuración de deploy
# ─────────────────────────────────────────────────────────────────────────
# Dejar vacío si no usas Oracle Cloud, o configurar para deploy automatizado

# Región de Oracle Cloud
OCI_REGION=us-ashburn-1

# Container Registry (OCIR)
OCIR_REGION=iad  # ashburn -> iad, phoenix -> phx, etc.
OCIR_NAMESPACE=tu_namespace_aqui
OCIR_REPO=bbva-seguros

# Compartimento para recursos
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your_compartment_id

# VCN y subnet
OCI_VCN_ID=ocid1.vcn.oc1.iad.your_vcn_id
OCI_SUBNET_ID=ocid1.subnet.oc1.iad.your_subnet_id

# ─────────────────────────────────────────────────────────────────────────
# 🔒 SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────
# Secret key para sesiones (generar: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here_change_in_production

# CORS - dominios permitidos
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://tu-dominio.com

# ─────────────────────────────────────────────────────────────────────────
# ℹ️  NOTAS DE SEGURIDAD
# ─────────────────────────────────────────────────────────────────────────
# 1. CAMBIAR TODAS LAS CONTRASEÑAS antes de deploy a producción
# 2. Generar SECRET_KEY seguro: python -c "import secrets; print(secrets.token_hex(32))"
# 3. Usar credenciales de aplicación para Instagram, no la contraseña real
# 4. En Oracle Cloud, usar Oracle Vault para almacenar secretos
# 5. No usar NUNCA contraseñas débiles como "password123"
# 6. Rotar credenciales regularmente
