# ─────────────────────────────────────────────────────────────
# Plantilla de variables de entorno.
# Copiá este archivo como ".env" y completá con tus datos reales.
# El .env real NO se sube al repositorio (está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Tu correo Gmail
EMAIL_ADDRESS=tucorreo@gmail.com

# Contraseña de APLICACIÓN de Gmail (16 caracteres, sin espacios).
# Se genera en https://myaccount.google.com/apppasswords
# (NO es tu contraseña normal de Gmail)
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx

# Ruta a tu CV en PDF (relativa o absoluta)
CV_FILE_PATH=cv.pdf

# (Opcional) API key de Claude para el chat con los agentes
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5-20251001
